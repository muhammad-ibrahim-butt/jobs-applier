# Apify
APIFY_API_TOKEN=
APIFY_ACTOR_ID=openclawai/job-board-scraper

# Search (overridden by config.yaml if present)
SEARCH_QUERIES=software engineer,backend developer
SEARCH_LOCATION=Remote
SEARCH_COUNTRY=USA

# Apply limits — keep interval high on Apify free tier
DAILY_APPLY_CAP=25
RUN_INTERVAL_MINUTES=180
DRY_RUN=false

# Email (SMTP)
# Port 465 -> SSL (SMTP_USE_SSL=true). Port 587 -> STARTTLS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_SSL=
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=
EMAIL_ENABLED=false

# Paths
PROFILE_PATH=./profile.yaml
CONFIG_PATH=./config.yaml
RESUME_PATH=./resume.pdf
DATABASE_PATH=./data/applications.db
BROWSER_USER_DATA_DIR=./sessions/chromium
QUESTIONS_CACHE_PATH=./data/questions.json

# Logging
LOG_LEVEL=INFO
